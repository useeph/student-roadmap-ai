// Student Roadmap AI - PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon: use pooled URL for app; use direct (non-pooler) URL for migrations — see .env.example
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  STUDENT
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(STUDENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  studentProfile StudentProfile?
}

model StudentProfile {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity
  name           String
  age            Int?
  gradeLevel     String?
  graduationYear Int?
  gpa            Float?

  // Academics
  currentClasses   String[]
  intendedMajors   String[]
  intendedIndustry String?
  targetColleges   String[]

  // Activities & Background
  interests        String[]
  extracurriculars String[]
  awards           String[]
  leadershipExp    String[]
  githubUrl        String?
  portfolioUrl     String?

  // Capacity & Constraints
  hoursPerWeek Float?
  constraints  String?
  goals        String?
  testScores   Json?

  roadmap Roadmap?
}

model Roadmap {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  studentId String   @unique
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  studentSummary            String?  @db.Text
  strengthsAnalysis         String?  @db.Text
  gapsAnalysis               String?  @db.Text
  recommendedExtracurriculars Json?
  recommendedProjects        Json?
  courseworkSuggestions     Json?
  competitions              Json?
  internshipsPrograms       Json?
  timeline3Month            Json?
  timeline6Month            Json?
  timeline12Month           Json?
  collegeCompetitiveness    Json?
  topActions                  Json?
  citations                   Json?
  admissionsStrategyOptimizer Json?

  strategySection   Json?
  essayIdeasSection Json?
}
